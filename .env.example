# =============================================
# Framer (required)
# =============================================
FRAMER_PROJECT_URL=https://framer.com/projects/YOUR-PROJECT-ID
FRAMER_API_KEY=your-framer-api-key
AUTH_TOKEN=your-secret-bearer-token

# =============================================
# Timezone (optional — defaults to America/New_York)
# =============================================
# Framer displays date values as-is without timezone conversion.
# This setting ensures your posts show the correct local time.
TIMEZONE=America/New_York

# =============================================
# Bluesky (optional — remove to skip)
# =============================================
BLUESKY_HANDLE=your-handle.bsky.social
BLUESKY_APP_PASSWORD=your-app-password

# =============================================
# Mastodon (optional — remove to skip)
# =============================================
MASTODON_INSTANCE_URL=https://mastodon.social
MASTODON_ACCESS_TOKEN=your-mastodon-token

# =============================================
# Threads (optional — remove to skip)
# =============================================
THREADS_USER_ID=your-threads-user-id
THREADS_ACCESS_TOKEN=your-threads-long-lived-token
